# Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# Replace with your MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@clustername.mongodb.net/database-name?retryWrites=true&w=majority

# Anthropic API Key (Claude)
# Get a new API key from https://console.anthropic.com/
# The key should start with sk-ant-api03-
ANTHROPIC_API_KEY=your-anthropic-api-key

# Anthropic Model (defaults to claude-opus-4-6 if not set)
ANTHROPIC_MODEL=claude-opus-4-6

